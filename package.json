{
  "name": "poe2-checklist-overlay",
  "version": "0.1.5",
  "private": true,
  "description": "A small always-on-top checklist overlay for games.",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/fewanjb12312/POE2.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.local.poe2-checklist-overlay",
    "productName": "POE2 Checklist Overlay",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "fewanjb12312",
        "repo": "POE2"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "assets/**/*",
      "data/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "POE2 Checklist Overlay"
    }
  }
}
